# Kalshi API (optional - markets are public, balance needs auth)
# In local dev, do NOT set VITE_KALSHI_API_BASE — the app uses Vite's /api/kalshi proxy (avoids CORS).
# For production builds only, you can set:
# VITE_KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
VITE_KALSHI_API_KEY_ID=
VITE_KALSHI_API_PRIVATE_KEY=

# Series tickers (override if Kalshi uses different tickers)
# VITE_KALSHI_SERIES_COLLEGE_BASKETBALL=KXNCAAMBGAME
# VITE_KALSHI_SERIES_NBA=KXNBAGAME
# VITE_KALSHI_SERIES_CS2=KXCS2GAME
# VITE_KALSHI_SERIES_LOL=KXLOLGAME
# VITE_KALSHI_SERIES_VALORANT=KXVALORANTGAME
