# Copy to .env and fill in
PORT=3001
KALSHI_API_KEY_ID=your_api_key_id

# REST signing strips ?query from the path (Kalshi requirement). If you see
# INCORRECT_API_KEY_SIGNATURE, verify key id + PEM pair and env PEM formatting.

# Private key: use ONE of these formats:
# 1) Multi-line (paste as-is between the quotes):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
# MIIEvgIBADANBg...
# -----END PRIVATE KEY-----"
#
# 2) Single-line with \n (backslash-n):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
